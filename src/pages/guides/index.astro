---
import { getCollection } from 'astro:content';
import site from '../../../site.config.json';
import Base from '../../layouts/Base.astro';

const articles = (await getCollection('articles', ({ data }) => !data.draft))
  .sort((a, b) => +b.data.publishDate - +a.data.publishDate);
const fmt = (d: Date) => d.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });
---
<Base title={`Articles | ${site.BRAND}`} description={`All articles from ${site.BRAND}.`}>
<header class="nav">
    <a class="brand" href="/"><span class="coin-slot" aria-hidden="true"><i></i></span>Vending<span class="hl">Startup</span></a>
    <nav aria-label="Main navigation"><a href="/guides/">Articles</a>
      <a href="/#guide">Guide</a><a href="/#tool">Calculator</a><a href="/#checklist">Locations</a><a href="/#faq">FAQ</a>
    </nav>
    <a class="btn sm" href="/#guide">Get the free guide</a>
  </header>
<div class="ad">Advertisement</div>
  <main class="guides">
    <h1>Articles</h1>
    <ul>
      {articles.map((a) => (
        <li>
          <a href={`/${a.id}/`}>{a.data.title}</a>
          <p>{a.data.description}</p>
          <small>{fmt(a.data.updatedDate ?? a.data.publishDate)}</small>
        </li>
      ))}
    </ul>
    {articles.length === 0 && <p>Articles are coming soon.</p>}
  </main>
<div class="ad">Advertisement</div>
<footer>
    <a class="brand" href="/"><span class="coin-slot" aria-hidden="true"><i></i></span>Vending<span class="hl">Startup</span></a>
    <nav><a href="/guides/">Articles</a><a href="/#tool">Calculator</a><a href="/#checklist">Checklist</a><a href="/#guide">Guide</a><a href="/about/">About</a><a href="/contact/">Contact</a><a href="/privacy/">Privacy</a><a href="/terms/">Terms</a><a href="/disclosure/">Disclosure</a><a href="/editorial/">Editorial</a></nav>
    <p>Results depend on your locations and effort. VendingStartup provides educational estimates, not income guarantees or legal, tax, or financial advice.</p>
    <small>&copy; 2026 VendingStartup</small>
  </footer>
</Base>

<style>
  .guides { max-width: 760px; margin: 0 auto; padding: 40px 20px 80px; }
  ul { list-style: none; padding: 0; }
  li { margin: 24px 0; }
  li a { font-weight: 700; font-size: 20px; }
  li p { margin: 4px 0; }
  small { opacity: .7; }
</style>
