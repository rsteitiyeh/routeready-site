---
import { getCollection } from 'astro:content';
import site from '../../../site.config.json';
import Base from '../../layouts/Base.astro';

const articles = (await getCollection('articles', ({ data }) => !data.draft))
  .sort((a, b) => +b.data.publishDate - +a.data.publishDate);
const fmt = (d: Date) => d.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });
---
<Base title={`Articles | ${site.BRAND}`} description={`All articles from ${site.BRAND}.`}>
<header class="nav">
    <a class="brand" href="/"><span class="coin-slot" aria-hidden="true"><i></i></span>Vending<span class="hl">Startup</span></a>
    <nav aria-label="Main navigation"><a href="/guides/">Articles</a>
      <a href="/#guide">Guide</a><a href="/#tool">Calculator</a><a href="/#checklist">Locations</a><a href="/#faq">FAQ</a>
    </nav>
    <a class="btn sm" href="/#guide">Get the free guide</a>
  </header>
<a href="https://hop.clickbank.net/?affiliate=soloaiclub&vendor=videly&tid=vending_banner" rel="sponsored nofollow noopener" target="_blank" class="ad ad-filled" style="display:flex;align-items:center;justify-content:space-between;gap:16px;width:min(970px,calc(100% - 32px));margin:27px auto;padding:14px 22px;border-radius:8px;background:linear-gradient(135deg,var(--navy,#12233b) 0%,var(--ink2,#1f2937) 100%);color:#fff;text-decoration:none;box-shadow:0 2px 10px rgba(0,0,0,.12);flex-wrap:wrap"><span style="display:flex;flex-direction:column;gap:2px;min-width:0"><span style="font:700 9px ui-monospace,monospace;letter-spacing:1.6px;text-transform:uppercase;opacity:.65">Sponsored</span><span style="font:700 15px 'Inter',sans-serif">Videly — Video SEO Software</span><span style="font:400 12.5px 'Inter',sans-serif;opacity:.85">Get your new route or business found on YouTube and Google. One-time price.</span></span><span style="flex:0 0 auto;padding:10px 18px;border-radius:5px;background:var(--gold,#c9a24b);color:#12233b;font:700 13px 'Inter',sans-serif;white-space:nowrap">See how it works →</span></a>
  <main class="guides">
    <h1>Articles</h1>
    <ul>
      {articles.map((a) => (
        <li>
          <a href={`/${a.id}/`}>{a.data.title}</a>
          <p>{a.data.description}</p>
          <small>{fmt(a.data.updatedDate ?? a.data.publishDate)}</small>
        </li>
      ))}
    </ul>
    {articles.length === 0 && <p>Articles are coming soon.</p>}
  </main>
<a href="https://hop.clickbank.net/?affiliate=soloaiclub&vendor=videly&tid=vending_banner" rel="sponsored nofollow noopener" target="_blank" class="ad ad-filled" style="display:flex;align-items:center;justify-content:space-between;gap:16px;width:min(970px,calc(100% - 32px));margin:27px auto;padding:14px 22px;border-radius:8px;background:linear-gradient(135deg,var(--navy,#12233b) 0%,var(--ink2,#1f2937) 100%);color:#fff;text-decoration:none;box-shadow:0 2px 10px rgba(0,0,0,.12);flex-wrap:wrap"><span style="display:flex;flex-direction:column;gap:2px;min-width:0"><span style="font:700 9px ui-monospace,monospace;letter-spacing:1.6px;text-transform:uppercase;opacity:.65">Sponsored</span><span style="font:700 15px 'Inter',sans-serif">Videly — Video SEO Software</span><span style="font:400 12.5px 'Inter',sans-serif;opacity:.85">Get your new route or business found on YouTube and Google. One-time price.</span></span><span style="flex:0 0 auto;padding:10px 18px;border-radius:5px;background:var(--gold,#c9a24b);color:#12233b;font:700 13px 'Inter',sans-serif;white-space:nowrap">See how it works →</span></a>
<footer>
    <a class="brand" href="/"><span class="coin-slot" aria-hidden="true"><i></i></span>Vending<span class="hl">Startup</span></a>
    <nav><a href="/guides/">Articles</a><a href="/#tool">Calculator</a><a href="/#checklist">Checklist</a><a href="/#guide">Guide</a><a href="/about/">About</a><a href="/contact/">Contact</a><a href="/privacy/">Privacy</a><a href="/terms/">Terms</a><a href="/disclosure/">Disclosure</a><a href="/editorial/">Editorial</a></nav>
    <p>Results depend on your locations and effort. VendingStartup provides educational estimates, not income guarantees or legal, tax, or financial advice.</p>
    <small>&copy; 2026 VendingStartup</small>
  </footer>
</Base>

<style>
  .guides { max-width: 760px; margin: 0 auto; padding: 40px 20px 80px; }
  ul { list-style: none; padding: 0; }
  li { margin: 24px 0; }
  li a { font-weight: 700; font-size: 20px; }
  li p { margin: 4px 0; }
  small { opacity: .7; }
</style>
