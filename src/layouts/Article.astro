---
import Base from './Base.astro';
import site from '../../site.config.json';
import { extractFaq } from '../lib/faq.mjs';

interface Props {
  entry: any;        // content collection entry
  related?: { title: string; slug: string; description?: string }[];
}
const { entry, related = [] } = Astro.props;
const { title, description, publishDate, updatedDate, author } = entry.data;
const updated = updatedDate ?? publishDate;
const authorName = author ?? site.author.name;
const canonical = new URL(`/${entry.id}/`, site.SITE).href;

const faqs = extractFaq(entry.body);
const graph = [];
graph.push({
  '@type': 'Article',
  headline: title,
  description,
  author: { '@type': 'Organization', name: authorName, url: site.SITE },
  publisher: { '@type': 'Organization', name: site.BRAND },
  datePublished: publishDate.toISOString().slice(0, 10),
  dateModified: updated.toISOString().slice(0, 10),
  mainEntityOfPage: canonical
});
if (faqs.length) {
  graph.push({
    '@type': 'FAQPage',
    mainEntity: faqs.map(f => ({
      '@type': 'Question',
      name: f.q,
      acceptedAnswer: { '@type': 'Answer', text: f.a }
    }))
  });
}
const jsonld = JSON.stringify({ '@context': 'https://schema.org', '@graph': graph });
const fmt = (d) => d.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });
---
