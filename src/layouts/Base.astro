---
import site from '../../site.config.json';
interface Props {
  title: string;
  description?: string;
  /** force noindex even post-stealth (e.g. 404, guides while thin) */
  noindex?: boolean;
  ogType?: string;
}
const { title, description = '', noindex = false, ogType = 'website' } = Astro.props;
const robots = site.stealth || noindex ? 'noindex, nofollow' : 'index, follow';
const canonical = new URL(Astro.url.pathname, site.SITE).href;
const ga4 = (site.ga4 && site.ga4.measurementId) || '';
---
<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>{title}</title>
  {description && <meta name="description" content={description} />}
  <meta name="robots" content={robots} />
  <link rel="canonical" href={canonical} />
  <meta property="og:title" content={title} />
  {description && <meta property="og:description" content={description} />}
  <meta property="og:type" content={ogType} />
  <meta property="og:url" content={canonical} />
  <slot name="head" />
  {ga4 && (
    <Fragment>
      {/* Google Consent Mode v2 — analytics_storage denied until the visitor accepts.
          GA4 still receives cookieless pings while denied, so traffic is measured
          from day one (Raptive requires GA history and it cannot be backfilled). */}
      <script is:inline>
        window.dataLayer = window.dataLayer || [];
        function gtag(){dataLayer.push(arguments);}
        var __c = null;
        try { __c = localStorage.getItem('consent-analytics'); } catch (e) {}
        gtag('consent', 'default', {
          ad_storage: 'denied',
          ad_user_data: 'denied',
          ad_personalization: 'denied',
          analytics_storage: __c === 'granted' ? 'granted' : 'denied'
        });
      </script>
      <script is:inline async src={`https://www.googletagmanager.com/gtag/js?id=${ga4}`}></script>
      <script is:inline define:vars={{ ga4 }}>
        gtag('js', new Date());
        gtag('config', ga4);
      </script>
    </Fragment>
  )}
</head>
<body>
  <slot />

  {ga4 && (
    <div id="cookie-banner" class="cookie-banner" hidden>
      <p>
        We use cookies for analytics to understand what's useful here. Ads and
        affiliate links, where present, are always disclosed. See our
        <a href="/privacy/">privacy policy</a>.
      </p>
      <div class="cookie-actions">
        <button type="button" data-consent="denied" class="cookie-btn ghost">Decline</button>
        <button type="button" data-consent="granted" class="cookie-btn">Accept</button>
      </div>
    </div>
  )}

  <script is:inline>
    // ---- Cookie consent (interim). Mediavine's CMP replaces this at Journey approval. ----
    const banner = document.getElementById('cookie-banner');
    if (banner) {
      let stored = null;
      try { stored = localStorage.getItem('consent-analytics'); } catch (e) {}
      if (!stored) banner.hidden = false;
      banner.querySelectorAll('[data-consent]').forEach((b) => {
        b.addEventListener('click', () => {
          const v = b.getAttribute('data-consent');
          try { localStorage.setItem('consent-analytics', v); } catch (e) {}
          if (window.gtag) window.gtag('consent', 'update', { analytics_storage: v });
          banner.hidden = true;
        });
      });
    }
  </script>

  <script>
    // Global subscribe handler: any <form data-subscribe> posts the email to
    // /api/subscribe, which stores it in D1 AND subscribes it to this site's
    // MailerLite group (which triggers magnet delivery + the nurture sequence).
    // The file is also handed over instantly so the visitor never waits on email.
    import site from '../../site.config.json';
    const magnet = site.magnet || {};
    document.querySelectorAll('form[data-subscribe]').forEach((form) => {
      form.addEventListener('submit', async (e) => {
        e.preventDefault();
        const input = form.querySelector('input[type="email"]');
        const btn = form.querySelector('button');
        const email = input && input.value ? input.value.trim() : '';
        if (!email) return;
        if (btn) { btn.disabled = true; btn.dataset.orig = btn.textContent; btn.textContent = '...'; }
        let ok = false;
        try {
          const r = await fetch('/api/subscribe', {
            method: 'POST',
            headers: { 'content-type': 'application/json' },
            body: JSON.stringify({ email })
          });
          ok = r.ok;
        } catch (err) {}
        const msg = document.createElement('p');
        msg.className = 'subscribe-done';
        if (ok && magnet.file) {
          const a = document.createElement('a');
          a.href = magnet.file; a.download = ''; document.body.appendChild(a); a.click(); a.remove();
          msg.innerHTML = (magnet.doneMessage || 'You are in - your download is starting now.') +
            ' <a href="' + magnet.file + '" download>Download did not start?</a>';
        } else if (ok) {
          msg.textContent = 'You are in - check your inbox.';
        } else {
          msg.textContent = 'Something went wrong - please try again.';
          if (btn) { btn.disabled = false; btn.textContent = btn.dataset.orig; }
        }
        form.insertAdjacentElement('afterend', msg);
        if (ok) form.hidden = true;
      });
    });
  </script>


  <script is:inline>
    (function () {
      document.addEventListener('click', function (e) {
        var el = e.target.closest('a.ad-filled, aside.offer-box a');
        if (!el) return;
        if (typeof gtag !== 'function') return;
        var slot = el.closest('aside.offer-box') ? 'offer_box' : 'banner';
        gtag('event', 'offer_click', {
          site: window.location.hostname,
          slot: slot,
          target_url: el.href,
          page: window.location.pathname
        });
      }, true);
    })();
  </script>
  <style is:global>
    .cookie-banner[hidden] { display: none; }
    .cookie-banner {
      position: fixed; bottom: 0; left: 0; right: 0; z-index: 9999;
      display: flex; flex-wrap: wrap; gap: 12px 24px;
      align-items: center; justify-content: center;
      padding: 14px 20px; background: #16181B; color: #F4F2ED;
      font-family: system-ui, -apple-system, 'Segoe UI', Roboto, sans-serif; font-size: 14px;
      box-shadow: 0 -2px 18px rgba(0,0,0,.22);
    }
    .cookie-banner p { margin: 0; max-width: 70ch; }
    .cookie-banner a { color: inherit; text-decoration: underline; }
    .cookie-actions { display: flex; gap: 10px; }
    .cookie-btn {
      border: 0; border-radius: 6px; padding: 9px 18px; cursor: pointer;
      font: inherit; font-weight: 700; background: #F4F2ED; color: #16181B;
    }
    .cookie-btn.ghost { background: transparent; color: #F4F2ED; border: 1px solid rgba(244,242,237,.45); }
    .cookie-btn:focus-visible { outline: 2px solid #fff; outline-offset: 2px; }
  </style>

  <style is:global>
:root{--cream:#faf5ec;--paper:#fffaf1;--red:#d92f2f;--red-dark:#a91f25;--brown:#56382d;--ink:#28231f;--muted:#6c5f55;--yellow:#f5bd3d;--blue:#70a7a3;--line:#cdbfae}
  *{box-sizing:border-box}html{scroll-behavior:smooth}
  body{margin:0;background:var(--cream);color:var(--ink);font-family:"Trebuchet MS",Arial,sans-serif;line-height:1.55}
  a{color:inherit;text-decoration:none}button,input,select{font:inherit}
  .sr{position:absolute;width:1px;height:1px;overflow:hidden;clip:rect(0,0,0,0)}
  .nav{position:sticky;z-index:20;top:0;padding:12px clamp(18px,5vw,72px);display:flex;align-items:center;gap:30px;background:rgba(250,245,236,.95);border-bottom:2px solid var(--ink);backdrop-filter:blur(12px)}
  .brand{display:flex;align-items:center;gap:10px;font-family:Rockwell,"Roboto Slab",Georgia,serif;font-size:1.45rem;font-weight:900;letter-spacing:-.05em}
  .brand .hl{color:var(--red)}
  .coin-slot{width:30px;height:30px;border:2px solid var(--ink);border-radius:50%;background:var(--yellow);display:grid;place-items:center;box-shadow:2px 2px 0 var(--ink)}
  .coin-slot i{width:4px;height:16px;border-radius:9px;background:var(--ink);transform:rotate(24deg);display:block}
  .nav nav{display:flex;gap:26px;margin-left:auto}.nav nav a{font-size:.88rem;font-weight:800}.nav nav a:hover{text-decoration:underline}
  .btn,form.email button{display:inline-flex;justify-content:center;align-items:center;border:2px solid var(--ink);border-radius:999px;padding:13px 20px;background:var(--red);color:#fff;font-weight:900;box-shadow:0 5px 0 var(--ink);cursor:pointer;transition:.15s}
  .btn:hover,form.email button:hover{background:var(--red-dark);transform:translateY(2px);box-shadow:0 3px 0 var(--ink)}
  .btn.sm{padding:9px 16px;font-size:.8rem}
  .ad{height:90px;width:min(970px,calc(100% - 32px));margin:27px auto;display:grid;place-items:center;border:1px dashed #b8aa9a;border-radius:10px;background:rgba(255,255,255,.28);color:#918477;font:11px Arial;letter-spacing:1.8px;text-transform:uppercase}
  .section{max-width:1240px;margin:auto;padding:105px clamp(20px,5vw,72px)}
  .eyebrow{display:flex;align-items:center;gap:10px;margin:0 0 18px;font-size:.76rem;font-weight:900;letter-spacing:.12em;text-transform:uppercase;color:var(--brown)}
  .eyebrow.light{color:var(--brown)}
  .hero{max-width:1240px;margin:auto;min-height:600px;display:grid;grid-template-columns:1.08fr .92fr;align-items:center;gap:clamp(50px,7vw,100px);padding:80px clamp(20px,5vw,72px)}
  h1,h2{font-family:Rockwell,"Roboto Slab",Georgia,serif;font-weight:900;line-height:.97;letter-spacing:-.055em}
  .hero h1{max-width:760px;margin:0;font-size:clamp(3rem,6vw,6rem)}
  .hero h1 em{color:var(--red);font-style:normal;text-decoration:underline;text-decoration-thickness:7px;text-decoration-color:var(--yellow);text-underline-offset:5px}
  .lede{max-width:650px;margin:28px 0;font-size:clamp(1.05rem,1.5vw,1.3rem);color:var(--brown)}
  form.email{display:flex;gap:10px;max-width:650px;padding:19px;border:2px solid var(--ink);border-radius:22px;background:var(--paper);box-shadow:7px 7px 0 var(--ink)}
  form.email input{flex:1;min-width:0;padding:14px 18px;border:2px solid var(--ink);border-radius:999px;background:#fff}
  form.email input:focus{outline:3px solid var(--yellow)}
  .micro{font-size:.8rem;color:var(--muted);margin:10px 0 0}
  .hero-micro{display:flex;flex-wrap:wrap;gap:16px;margin-top:25px;color:var(--brown);font-size:.83rem;font-weight:800}
  .machine{max-width:400px;margin:auto;padding:18px 18px 24px;border:4px solid var(--ink);border-radius:34px;background:var(--red);box-shadow:12px 14px 0 var(--brown);transform:rotate(1.2deg)}
  .machine-top{display:flex;align-items:center;justify-content:space-between;margin-bottom:12px;color:#fff;font-family:Rockwell,Georgia,serif;letter-spacing:.06em}
  .machine-top b{font-size:.72rem;padding:4px 7px;border:1px solid #fff;border-radius:4px}
  .machine-window{min-height:220px;padding:20px 15px;border:4px solid var(--ink);border-radius:18px;background:#231e1b}
  .shelf-row{display:grid;grid-template-columns:repeat(3,1fr);gap:11px;margin-bottom:20px}
  .snack{min-height:70px;padding:7px 6px;border-radius:12px 12px 7px 7px;color:white;text-align:center}
  .snack span{display:block;font-size:.62rem;text-align:left}
  .snack b{display:block;margin:6px 0;font-family:Rockwell,Georgia,serif;font-size:.82rem}
  .snack small{background:#fff;color:var(--ink);padding:2px 5px;border-radius:3px;font-weight:900}
  .red{background:#cf3436}.yellow{background:#d49416}.blue{background:#447e7a}.brown{background:#79503d}
  .machine-controls{display:grid;grid-template-columns:1fr auto;gap:9px;margin-top:13px}
  .display{padding:10px;background:#2a1e1c;border:2px solid var(--ink);border-radius:7px;color:#97e0a8;font-family:monospace;font-size:.74rem}
  .keypad{padding:8px;border:2px solid var(--ink);border-radius:6px;background:var(--paper);font-weight:900}
  .pickup{width:70%;margin:18px auto 0;padding:9px 20px;border:4px solid var(--ink);border-radius:7px;background:#241d19;color:#fff;text-align:center}
  .pickup span{font-size:.55rem;letter-spacing:.14em}
  .proof{max-width:1100px;margin:20px auto 0;display:flex;justify-content:space-between;align-items:center;gap:25px;flex-wrap:wrap;padding:24px clamp(20px,5vw,0);background:var(--brown);color:#fff;border:3px solid var(--ink);border-radius:20px;box-shadow:8px 8px 0 var(--yellow)}
  .proof strong{color:var(--yellow);font-size:1.7rem}.proof small{display:block}
  .badges{display:flex;flex-wrap:wrap;gap:8px}.badges span{padding:7px 10px;border:1px solid #ffffff40;border-radius:99px;font-size:12px}
  .head{max-width:680px;margin-bottom:42px}
  .head h2,.schedule h2,.offer h2,.final h2{margin:0 0 15px;font-size:clamp(2.5rem,4.7vw,5rem)}
  .problem{background:linear-gradient(#fff,#f4ece0)}
  .cards{display:grid;grid-template-columns:repeat(2,1fr);gap:20px}
  .card{padding:32px;border:3px solid var(--ink);border-radius:27px;background:var(--paper);box-shadow:8px 8px 0 var(--ink)}
  .card.alt{background:#f4d57f}
  .card h3{margin:0 0 10px;font-size:1.5rem;font-family:Rockwell,Georgia,serif}
  .num{color:var(--red);font-size:.7rem;font-weight:900}
  .schedule{position:relative;overflow:hidden;display:grid;grid-template-columns:.85fr 1.15fr;gap:70px;align-items:center;background:var(--blue);color:#fff;border:3px solid var(--ink);border-radius:34px;max-width:1240px;margin:20px auto;box-shadow:10px 10px 0 var(--ink)}
  .schedule h2{color:#fff}
  .check{padding:34px;color:var(--ink)}.check ul{padding:0;list-style:none}
  .check li{padding:9px 0;border-bottom:1px solid #c7e6e4;color:#fff}.check li:before{content:"OK";margin-right:10px;color:var(--yellow);font-weight:900}
  .compact{display:grid}
  .offer{display:grid;grid-template-columns:1.35fr .65fr;gap:70px;align-items:center;background:var(--brown);color:#fff;border:4px solid var(--ink);border-radius:35px;max-width:1240px;margin:20px auto;box-shadow:12px 12px 0 var(--red)}
  .offer h2{color:var(--yellow)}
  .offer blockquote{margin:20px 0 0;padding:15px 0 15px 20px;border-left:5px solid var(--red);font-family:Georgia,serif;font-size:1.05rem;font-style:italic}
  .chips{display:flex;gap:8px;flex-wrap:wrap;margin-top:20px}.chips span{padding:7px 12px;border-radius:99px;background:rgba(255,255,255,.12);font-size:13px;font-weight:800}
  .price{text-align:center;padding:35px;background:var(--yellow);border-radius:20px;color:var(--ink)}
  .price>strong{display:block;font-size:60px;line-height:1.2;font-family:Rockwell,Georgia,serif}
  .price .btn{display:flex;margin-top:10px}.price small{display:block;margin-top:17px}
  .calc-wrap{max-width:1240px;margin:auto;padding:105px clamp(18px,5vw,72px)}.calc-wrap .head h2,.calc-wrap .head p{color:var(--ink)}
  .byline{display:grid;grid-template-columns:150px 1fr;gap:34px;align-items:center;background:var(--paper);border:3px solid var(--ink);border-radius:28px;max-width:1240px;margin:20px auto;padding:45px}
  .byline q{display:block;margin-top:16px;padding:12px 18px;border-left:5px solid var(--red);font-family:Georgia,serif;font-size:1.05rem;font-style:italic}
  .avatar{width:145px;height:145px;display:grid;place-items:center;border-radius:50%;background:var(--yellow);font-size:10px;border:4px solid var(--ink);box-shadow:8px 8px 0 var(--red)}
  .faq{background:#f4ece0}.faq-list{max-width:850px}
  .faq details{margin:10px 0;padding:0 20px;border:1px solid var(--line);border-radius:14px;background:var(--paper)}
  .faq summary{padding:19px 0;display:flex;justify-content:space-between;cursor:pointer;list-style:none;font-weight:900}
  .faq details p{margin:0 0 20px;color:var(--muted)}.faq summary span{font-size:24px;color:var(--red)}.faq details[open] summary span{transform:rotate(45deg)}
  .final{max-width:1160px;margin:70px auto 100px;padding:55px;text-align:center;color:#fff;background:var(--red);border:4px solid var(--ink);border-radius:34px;box-shadow:12px 12px 0 var(--yellow)}
  .final h2{color:#fff;font-size:clamp(2.6rem,5vw,4rem)}
  .actions{display:flex;justify-content:center;align-items:center;gap:25px;flex-wrap:wrap;margin-top:20px}
  .actions .btn{background:var(--paper);color:var(--ink);border-color:var(--ink)}
  .text-link{border-bottom:2px solid var(--yellow);font-weight:900}
  footer{padding:52px clamp(24px,5vw,72px);display:grid;grid-template-columns:1fr 1fr;gap:25px;background:#e9ddce;border-top:3px solid var(--ink)}
  footer nav{display:flex;gap:23px;justify-content:flex-end;flex-wrap:wrap;font-size:14px;font-weight:800}
  footer p{grid-column:1/-1;max-width:760px;font-size:13px;color:var(--muted)}

  /* ---- VendingStartup skin for the shared Tool engine ---- */
  .calc{background:var(--paper);border:4px solid var(--ink);border-radius:30px;box-shadow:10px 10px 0 var(--ink);overflow:hidden}
  .calc-inputs,.calc-results{padding:38px}
  .calc-field input,.calc-field select{border:2px solid var(--ink);border-radius:10px}
  .calc-results{background:var(--red);color:#fff}
  .calc-results.tone-warn{background:var(--yellow);color:var(--ink)}.calc-results.tone-bad{background:var(--brown);color:#fff}
  .calc-dot{background:var(--yellow)}
  .tone-warn .calc-dot{background:var(--red)}.tone-bad .calc-dot{background:var(--yellow)}
  .calc-disclaimer{color:inherit;opacity:.85}

  @media(max-width:1000px){.nav nav{display:none}.hero,.schedule,.offer{grid-template-columns:1fr}.byline{grid-template-columns:110px 1fr}.avatar{width:110px;height:110px}.cards{grid-template-columns:1fr}}
  @media(max-width:650px){.hero{padding-top:55px}.hero h1{font-size:clamp(2.6rem,14vw,3.6rem)}form.email{display:grid}.section{padding-top:75px;padding-bottom:75px}.calc-inputs,.calc-results{padding:25px 20px}.proof{flex-direction:column;align-items:flex-start}.byline{grid-template-columns:1fr;text-align:center}.actions{flex-direction:column}footer{grid-template-columns:1fr}footer nav{justify-content:flex-start;display:grid;grid-template-columns:1fr 1fr}}
  @media(prefers-reduced-motion:reduce){*,*:before,*:after{animation:none!important;transition:none!important;scroll-behavior:auto!important}}
  </style>
</body>
</html>
