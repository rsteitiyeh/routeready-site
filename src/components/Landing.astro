---
/**
 * VendingStartup landing - flattened from the approved design
 * (production sites/06-vending/VendingStartup-Standalone-HTML/index.html).
 * Calculator section mounts the shared Tool engine (Calculator.astro)
 * with a VendingStartup vending-machine skin below.
 */
import site from '../../site.config.json';
import Base from '../layouts/Base.astro';
import Tool from './Tool.astro';
---
<Base
  title="Vending Machine Business Plan & Profit Calculator | VendingStartup"
  description="Build a realistic vending machine business plan with VendingStartup. Compare startup costs, location commissions, licenses, machine prices, and route profit math."
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify({
      '@context': 'https://schema.org',
      '@type': 'FAQPage',
      mainEntity: [
        { '@type': 'Question', name: 'How much does it cost to start a vending machine business?', acceptedAnswer: { '@type': 'Answer', text: 'A practical one-machine start is often about $2,000-$4,000 for a used machine, initial stock, moving, card-reader setup, and local permits.' } },
        { '@type': 'Question', name: 'Do I need a license for a vending machine route?', acceptedAnswer: { '@type': 'Answer', text: 'Usually you need a general business license and a state sales-tax permit. Some cities require a vending permit, and health-department rules may apply to perishable products.' } },
        { '@type': 'Question', name: 'How much money does one vending machine make?', acceptedAnswer: { '@type': 'Answer', text: 'There is no honest universal average. A weak location may gross under $50 a month; a solid workplace can gross several hundred dollars.' } },
        { '@type': 'Question', name: 'What is a normal location commission?', acceptedAnswer: { '@type': 'Answer', text: 'Ten to twenty-five percent of gross sales is a common negotiating range, but it is not a rule.' } },
        { '@type': 'Question', name: 'Should I buy a new or used vending machine?', acceptedAnswer: { '@type': 'Answer', text: 'A professionally refurbished, parts-supported machine can be the better first-route value.' } },
        { '@type': 'Question', name: 'Can vending machines create passive income?', acceptedAnswer: { '@type': 'Answer', text: 'They can become systemized, but they are not passive at the start.' } }
      ]
    })} />
  </Fragment>

  <header class="nav">
    <a class="brand" href="#top"><span class="coin-slot" aria-hidden="true"><i></i></span>Vending<span class="hl">Startup</span></a>
    <nav aria-label="Main navigation"><a href="/guides/">Articles</a>
      <a href="#guide">Guide</a><a href="#tool">Calculator</a><a href="#checklist">Locations</a><a href="#faq">FAQ</a>
    </nav>
    <a class="btn sm" href="#guide">Get the free guide</a>
  </header>
  <a href="https://ca1f5epbv5j3wrjt2egforraqd.hop.clickbank.net/?tid=vending_banner" rel="sponsored nofollow noopener" target="_blank" class="ad ad-filled" style="display:flex;align-items:center;justify-content:space-between;gap:16px;width:min(970px,calc(100% - 32px));margin:27px auto;padding:14px 22px;border-radius:8px;background:linear-gradient(135deg,var(--navy,#12233b) 0%,var(--ink2,#1f2937) 100%);color:#fff;text-decoration:none;box-shadow:0 2px 10px rgba(0,0,0,.12);flex-wrap:wrap"><span style="display:flex;flex-direction:column;gap:2px;min-width:0"><span style="font:700 9px ui-monospace,monospace;letter-spacing:1.6px;text-transform:uppercase;opacity:.65">Sponsored</span><span style="font:700 15px 'Inter',sans-serif">Ultimate Small Shop</span><span style="font:400 12.5px 'Inter',sans-serif;opacity:.85">Set up a complete workshop in a small space on a real-world budget.</span></span><span style="flex:0 0 auto;padding:10px 18px;border-radius:5px;background:var(--gold,#c9a24b);color:#12233b;font:700 13px 'Inter',sans-serif;white-space:nowrap">See the guide →</span></a>

  <main id="top">
    <section class="hero">
      <div class="hero-copy">
        <p class="eyebrow"><span>A1</span> The no-hype route starter</p>
        <h1>Start a Vending Route That <em>Actually Pays</em> for Itself.</h1>
        <p class="lede">Machine prices, location commissions, and route math - the numbers most "vending gurus" won't show you.</p>
        <form class="email" data-subscribe method="post">
          <label class="sr" for="email1">Email address</label>
          <input id="email1" name="fields[email]" type="email" required placeholder="you@example.com" />
          <button>Send my checklist -&gt;</button>
        </form>
        <p class="micro">No spam. Just useful route math. Unsubscribe anytime.</p>
        <div class="hero-micro"><span>Free calculator</span><span>No franchise pitch</span><span>Built for first routes</span></div>
      </div>
      <div class="machine">
        <div class="machine-top"><span>VENDINGSTARTUP</span><b>SNACK MATH</b></div>
        <div class="machine-window">
          <div class="shelf-row">
            <div class="snack red"><span>A1</span><b>PLAN</b><small>FREE</small></div>
            <div class="snack yellow"><span>A2</span><b>COST</b><small>$2.5K</small></div>
            <div class="snack blue"><span>A3</span><b>LOCATE</b><small>75+</small></div>
          </div>
          <div class="shelf-row">
            <div class="snack brown"><span>B1</span><b>STOCK</b><small>50%</small></div>
            <div class="snack red"><span>B2</span><b>SELL</b><small>$2</small></div>
            <div class="snack yellow"><span>B3</span><b>NET</b><small>-&gt;</small></div>
          </div>
        </div>
        <div class="machine-controls"><div class="display">SELECT A1</div><div class="keypad">A1</div></div>
        <div class="pickup"><span>YOUR PLAN DROPS HERE</span></div>
      </div>
    </section>

    <section class="proof">
      <p><strong>Free</strong> route profit calculator <small>no signup required</small></p>
      <div class="badges"><span>$0 franchise fees</span><span>100% location-first math</span><span>No income guarantees. Just math.</span></div>
    </section>
    <a href="https://ca1f5epbv5j3wrjt2egforraqd.hop.clickbank.net/?tid=vending_banner" rel="sponsored nofollow noopener" target="_blank" class="ad ad-filled" style="display:flex;align-items:center;justify-content:space-between;gap:16px;width:min(970px,calc(100% - 32px));margin:27px auto;padding:14px 22px;border-radius:8px;background:linear-gradient(135deg,var(--navy,#12233b) 0%,var(--ink2,#1f2937) 100%);color:#fff;text-decoration:none;box-shadow:0 2px 10px rgba(0,0,0,.12);flex-wrap:wrap"><span style="display:flex;flex-direction:column;gap:2px;min-width:0"><span style="font:700 9px ui-monospace,monospace;letter-spacing:1.6px;text-transform:uppercase;opacity:.65">Sponsored</span><span style="font:700 15px 'Inter',sans-serif">Ultimate Small Shop</span><span style="font:400 12.5px 'Inter',sans-serif;opacity:.85">Set up a complete workshop in a small space on a real-world budget.</span></span><span style="flex:0 0 auto;padding:10px 18px;border-radius:5px;background:var(--gold,#c9a24b);color:#12233b;font:700 13px 'Inter',sans-serif;white-space:nowrap">See the guide →</span></a>

    <section class="section problem">
      <div class="head">
        <p class="eyebrow">Avoid the expensive lessons</p>
        <h2>Two mistakes can bury your first route.</h2>
        <p>The machine is not the business. The location and acquisition price are.</p>
      </div>
      <div class="cards">
        <article class="card"><span class="num">C1</span><h3>Bad locations kill routes.</h3><p>A machine in a dead hallway might do $30/month. A decent breakroom with 75+ employees can do $300-$500/month.</p></article>
        <article class="card alt"><span class="num">C2</span><h3>Overpriced machine scams.</h3><p>A used combo machine often costs $1,500-$3,500 refurbished. "Business opportunity" resellers may charge $7,000+ for a comparable unit.</p></article>
      </div>
    </section>

    <section id="checklist" class="section schedule">
      <div>
        <p class="eyebrow light">Free field tool</p>
        <h2>The Location Scouting Checklist</h2>
        <p>Walk into a potential account knowing what to count, what to ask, and when to walk away.</p>
      </div>
      <div class="check">
        <ul>
          <li>75+ on-site occupants?</li>
          <li>Few nearby food options?</li>
          <li>10-25% commission range known?</li>
          <li>Who decides on access and term?</li>
        </ul>
        <form class="email compact" data-subscribe method="post">
          <label class="sr" for="email2">Email address</label>
          <input id="email2" name="fields[email]" type="email" required placeholder="you@example.com" />
          <button>Email me the checklist -&gt;</button>
        </form>
      </div>
    </section>
    <a href="https://ca1f5epbv5j3wrjt2egforraqd.hop.clickbank.net/?tid=vending_banner" rel="sponsored nofollow noopener" target="_blank" class="ad ad-filled" style="display:flex;align-items:center;justify-content:space-between;gap:16px;width:min(970px,calc(100% - 32px));margin:27px auto;padding:14px 22px;border-radius:8px;background:linear-gradient(135deg,var(--navy,#12233b) 0%,var(--ink2,#1f2937) 100%);color:#fff;text-decoration:none;box-shadow:0 2px 10px rgba(0,0,0,.12);flex-wrap:wrap"><span style="display:flex;flex-direction:column;gap:2px;min-width:0"><span style="font:700 9px ui-monospace,monospace;letter-spacing:1.6px;text-transform:uppercase;opacity:.65">Sponsored</span><span style="font:700 15px 'Inter',sans-serif">Ultimate Small Shop</span><span style="font:400 12.5px 'Inter',sans-serif;opacity:.85">Set up a complete workshop in a small space on a real-world budget.</span></span><span style="flex:0 0 auto;padding:10px 18px;border-radius:5px;background:var(--gold,#c9a24b);color:#12233b;font:700 13px 'Inter',sans-serif;white-space:nowrap">See the guide →</span></a>

    <section id="guide" class="section offer">
      <div>
        <p class="eyebrow">The first-route manual</p>
        <h2>The VendingStartup Startup Guide</h2>
        <p>A practical vending machine business plan for buying one good machine, placing it deliberately, and knowing the math before you scale.</p>
        <blockquote>"This won't make you rich. It will keep you from wasting $5,000 on your first two mistakes."</blockquote>
        <div class="chips"><span>Machine buying guide</span><span>Licensing walkthrough</span><span>Outreach scripts</span><span>Route profit worksheet</span></div>
      </div>
      <div class="price">
        <p>VendingStartup guide</p>
        <strong>FREE</strong>
        <form class="email compact" data-subscribe method="post">
          <label class="sr" for="email3">Email address</label>
          <input id="email3" name="fields[email]" type="email" required placeholder="you@example.com" />
          <button type="submit">Send me the free guide</button>
        </form>
        <small>Instant digital access. No cost, ever.</small>
      </div>
    </section>

    <section id="tool" class="calc-wrap">
      <div class="head">
        <p class="eyebrow light">Free route calculator</p>
        <h2>Does your route math work?</h2>
        <p>Move the numbers. VendingStartup updates the estimate instantly - before you buy the machine.</p>
      </div>
      <Tool />
    </section>

    <section class="section byline">
      <div>
        <p class="eyebrow">Behind VendingStartup</p>
        <h2>{site.author.name}</h2>
        <p>{site.author.bio}</p>
        <q>I run a small local route and publish my real numbers.</q>
      </div>
    </section>
    <a href="https://ca1f5epbv5j3wrjt2egforraqd.hop.clickbank.net/?tid=vending_banner" rel="sponsored nofollow noopener" target="_blank" class="ad ad-filled" style="display:flex;align-items:center;justify-content:space-between;gap:16px;width:min(970px,calc(100% - 32px));margin:27px auto;padding:14px 22px;border-radius:8px;background:linear-gradient(135deg,var(--navy,#12233b) 0%,var(--ink2,#1f2937) 100%);color:#fff;text-decoration:none;box-shadow:0 2px 10px rgba(0,0,0,.12);flex-wrap:wrap"><span style="display:flex;flex-direction:column;gap:2px;min-width:0"><span style="font:700 9px ui-monospace,monospace;letter-spacing:1.6px;text-transform:uppercase;opacity:.65">Sponsored</span><span style="font:700 15px 'Inter',sans-serif">Ultimate Small Shop</span><span style="font:400 12.5px 'Inter',sans-serif;opacity:.85">Set up a complete workshop in a small space on a real-world budget.</span></span><span style="flex:0 0 auto;padding:10px 18px;border-radius:5px;background:var(--gold,#c9a24b);color:#12233b;font:700 13px 'Inter',sans-serif;white-space:nowrap">See the guide →</span></a>

    <section id="faq" class="section faq">
      <div class="head"><p class="eyebrow">Straight answers</p><h2>Vending business FAQs</h2></div>
      <div class="faq-list">
        <details open><summary>How much does it cost to start a vending machine business?<span>+</span></summary><p>A practical one-machine start is often about $2,000-$4,000 for a used machine, initial stock, moving, card-reader setup, and local permits.</p></details>
        <details><summary>Do I need a license for a vending machine route?<span>+</span></summary><p>Usually you need a general business license and a state sales-tax permit. Some cities require a vending permit, and health-department rules may apply to perishable products.</p></details>
        <details><summary>How much money does one vending machine make?<span>+</span></summary><p>There is no honest universal average. A weak location may gross under $50 a month; a solid workplace can gross several hundred dollars.</p></details>
        <details><summary>What is a normal location commission?<span>+</span></summary><p>Ten to twenty-five percent of gross sales is a common negotiating range, but it is not a rule.</p></details>
        <details><summary>Should I buy a new or used vending machine?<span>+</span></summary><p>A professionally refurbished, parts-supported machine can be the better first-route value. Verify card-reader compatibility and test every selection.</p></details>
        <details><summary>How many employees make a good workplace location?<span>+</span></summary><p>Seventy-five or more on-site employees is a useful first screen, not a guarantee. Access and nearby food alternatives matter too.</p></details>
        <details><summary>How often will I need to restock?<span>+</span></summary><p>Many small routes begin with weekly or every-other-week visits. Track sold units by product and visit.</p></details>
        <details><summary>Can vending machines create passive income?<span>+</span></summary><p>They can become systemized, but they are not passive at the start. Someone still has to stock, clean, repair, and reconcile the machines.</p></details>
      </div>
    </section>

    <section class="final">
      <p class="eyebrow light">Pick your next move</p>
      <h2>Run the numbers. Then build the route.</h2>
      <p>Use the free VendingStartup calculator now, or get the full startup guide - free - and avoid the expensive first-route guesses.</p>
      <div class="actions"><a class="btn" href="#tool">Use the free calculator</a><a class="text-link" href="#guide">Get the free guide -&gt;</a></div>
    </section>
  </main>

  <footer>
    <a class="brand" href="#top"><span class="coin-slot" aria-hidden="true"><i></i></span>Vending<span class="hl">Startup</span></a>
    <nav><a href="/guides/">Articles</a><a href="#tool">Calculator</a><a href="#checklist">Checklist</a><a href="#guide">Guide</a><a href="/about/">About</a><a href="/contact/">Contact</a><a href="/privacy/">Privacy</a><a href="/terms/">Terms</a><a href="/disclosure/">Disclosure</a><a href="/editorial/">Editorial</a></nav>
    <p>Results depend on your locations and effort. VendingStartup provides educational estimates, not income guarantees or legal, tax, or financial advice.</p>
    <small>&copy; 2026 VendingStartup</small>
  </footer>
</Base>

<style is:global>
  :root{--cream:#faf5ec;--paper:#fffaf1;--red:#d92f2f;--red-dark:#a91f25;--brown:#56382d;--ink:#28231f;--muted:#6c5f55;--yellow:#f5bd3d;--blue:#70a7a3;--line:#cdbfae}
  *{box-sizing:border-box}html{scroll-behavior:smooth}
  body{margin:0;background:var(--cream);color:var(--ink);font-family:"Trebuchet MS",Arial,sans-serif;line-height:1.55}
  a{color:inherit;text-decoration:none}button,input,select{font:inherit}
  .sr{position:absolute;width:1px;height:1px;overflow:hidden;clip:rect(0,0,0,0)}
  .nav{position:sticky;z-index:20;top:0;padding:12px clamp(18px,5vw,72px);display:flex;align-items:center;gap:30px;background:rgba(250,245,236,.95);border-bottom:2px solid var(--ink);backdrop-filter:blur(12px)}
  .brand{display:flex;align-items:center;gap:10px;font-family:Rockwell,"Roboto Slab",Georgia,serif;font-size:1.45rem;font-weight:900;letter-spacing:-.05em}
  .brand .hl{color:var(--red)}
  .coin-slot{width:30px;height:30px;border:2px solid var(--ink);border-radius:50%;background:var(--yellow);display:grid;place-items:center;box-shadow:2px 2px 0 var(--ink)}
  .coin-slot i{width:4px;height:16px;border-radius:9px;background:var(--ink);transform:rotate(24deg);display:block}
  .nav nav{display:flex;gap:26px;margin-left:auto}.nav nav a{font-size:.88rem;font-weight:800}.nav nav a:hover{text-decoration:underline}
  .btn,form.email button{display:inline-flex;justify-content:center;align-items:center;border:2px solid var(--ink);border-radius:999px;padding:13px 20px;background:var(--red);color:#fff;font-weight:900;box-shadow:0 5px 0 var(--ink);cursor:pointer;transition:.15s}
  .btn:hover,form.email button:hover{background:var(--red-dark);transform:translateY(2px);box-shadow:0 3px 0 var(--ink)}
  .btn.sm{padding:9px 16px;font-size:.8rem}
  .ad{height:90px;width:min(970px,calc(100% - 32px));margin:27px auto;display:grid;place-items:center;border:1px dashed #b8aa9a;border-radius:10px;background:rgba(255,255,255,.28);color:#918477;font:11px Arial;letter-spacing:1.8px;text-transform:uppercase}
  .section{max-width:1240px;margin:auto;padding:105px clamp(20px,5vw,72px)}
  .eyebrow{display:flex;align-items:center;gap:10px;margin:0 0 18px;font-size:.76rem;font-weight:900;letter-spacing:.12em;text-transform:uppercase;color:var(--brown)}
  .eyebrow.light{color:var(--brown)}
  .hero{max-width:1240px;margin:auto;min-height:600px;display:grid;grid-template-columns:1.08fr .92fr;align-items:center;gap:clamp(50px,7vw,100px);padding:80px clamp(20px,5vw,72px)}
  h1,h2{font-family:Rockwell,"Roboto Slab",Georgia,serif;font-weight:900;line-height:.97;letter-spacing:-.055em}
  .hero h1{max-width:760px;margin:0;font-size:clamp(3rem,6vw,6rem)}
  .hero h1 em{color:var(--red);font-style:normal;text-decoration:underline;text-decoration-thickness:7px;text-decoration-color:var(--yellow);text-underline-offset:5px}
  .lede{max-width:650px;margin:28px 0;font-size:clamp(1.05rem,1.5vw,1.3rem);color:var(--brown)}
  form.email{display:flex;gap:10px;max-width:650px;padding:19px;border:2px solid var(--ink);border-radius:22px;background:var(--paper);box-shadow:7px 7px 0 var(--ink)}
  form.email input{flex:1;min-width:0;padding:14px 18px;border:2px solid var(--ink);border-radius:999px;background:#fff}
  form.email input:focus{outline:3px solid var(--yellow)}
  .micro{font-size:.8rem;color:var(--muted);margin:10px 0 0}
  .hero-micro{display:flex;flex-wrap:wrap;gap:16px;margin-top:25px;color:var(--brown);font-size:.83rem;font-weight:800}
  .machine{max-width:400px;margin:auto;padding:18px 18px 24px;border:4px solid var(--ink);border-radius:34px;background:var(--red);box-shadow:12px 14px 0 var(--brown);transform:rotate(1.2deg)}
  .machine-top{display:flex;align-items:center;justify-content:space-between;margin-bottom:12px;color:#fff;font-family:Rockwell,Georgia,serif;letter-spacing:.06em}
  .machine-top b{font-size:.72rem;padding:4px 7px;border:1px solid #fff;border-radius:4px}
  .machine-window{min-height:220px;padding:20px 15px;border:4px solid var(--ink);border-radius:18px;background:#231e1b}
  .shelf-row{display:grid;grid-template-columns:repeat(3,1fr);gap:11px;margin-bottom:20px}
  .snack{min-height:70px;padding:7px 6px;border-radius:12px 12px 7px 7px;color:white;text-align:center}
  .snack span{display:block;font-size:.62rem;text-align:left}
  .snack b{display:block;margin:6px 0;font-family:Rockwell,Georgia,serif;font-size:.82rem}
  .snack small{background:#fff;color:var(--ink);padding:2px 5px;border-radius:3px;font-weight:900}
  .red{background:#cf3436}.yellow{background:#d49416}.blue{background:#447e7a}.brown{background:#79503d}
  .machine-controls{display:grid;grid-template-columns:1fr auto;gap:9px;margin-top:13px}
  .display{padding:10px;background:#2a1e1c;border:2px solid var(--ink);border-radius:7px;color:#97e0a8;font-family:monospace;font-size:.74rem}
  .keypad{padding:8px;border:2px solid var(--ink);border-radius:6px;background:var(--paper);font-weight:900}
  .pickup{width:70%;margin:18px auto 0;padding:9px 20px;border:4px solid var(--ink);border-radius:7px;background:#241d19;color:#fff;text-align:center}
  .pickup span{font-size:.55rem;letter-spacing:.14em}
  .proof{max-width:1100px;margin:20px auto 0;display:flex;justify-content:space-between;align-items:center;gap:25px;flex-wrap:wrap;padding:24px clamp(20px,5vw,0);background:var(--brown);color:#fff;border:3px solid var(--ink);border-radius:20px;box-shadow:8px 8px 0 var(--yellow)}
  .proof strong{color:var(--yellow);font-size:1.7rem}.proof small{display:block}
  .badges{display:flex;flex-wrap:wrap;gap:8px}.badges span{padding:7px 10px;border:1px solid #ffffff40;border-radius:99px;font-size:12px}
  .head{max-width:680px;margin-bottom:42px}
  .head h2,.schedule h2,.offer h2,.final h2{margin:0 0 15px;font-size:clamp(2.5rem,4.7vw,5rem)}
  .problem{background:linear-gradient(#fff,#f4ece0)}
  .cards{display:grid;grid-template-columns:repeat(2,1fr);gap:20px}
  .card{padding:32px;border:3px solid var(--ink);border-radius:27px;background:var(--paper);box-shadow:8px 8px 0 var(--ink)}
  .card.alt{background:#f4d57f}
  .card h3{margin:0 0 10px;font-size:1.5rem;font-family:Rockwell,Georgia,serif}
  .num{color:var(--red);font-size:.7rem;font-weight:900}
  .schedule{position:relative;overflow:hidden;display:grid;grid-template-columns:.85fr 1.15fr;gap:70px;align-items:center;background:var(--blue);color:#fff;border:3px solid var(--ink);border-radius:34px;max-width:1240px;margin:20px auto;box-shadow:10px 10px 0 var(--ink)}
  .schedule h2{color:#fff}
  .check{padding:34px;color:var(--ink)}.check ul{padding:0;list-style:none}
  .check li{padding:9px 0;border-bottom:1px solid #c7e6e4;color:#fff}.check li:before{content:"OK";margin-right:10px;color:var(--yellow);font-weight:900}
  .compact{display:grid}
  .offer{display:grid;grid-template-columns:1.35fr .65fr;gap:70px;align-items:center;background:var(--brown);color:#fff;border:4px solid var(--ink);border-radius:35px;max-width:1240px;margin:20px auto;box-shadow:12px 12px 0 var(--red)}
  .offer h2{color:var(--yellow)}
  .offer blockquote{margin:20px 0 0;padding:15px 0 15px 20px;border-left:5px solid var(--red);font-family:Georgia,serif;font-size:1.05rem;font-style:italic}
  .chips{display:flex;gap:8px;flex-wrap:wrap;margin-top:20px}.chips span{padding:7px 12px;border-radius:99px;background:rgba(255,255,255,.12);font-size:13px;font-weight:800}
  .price{text-align:center;padding:35px;background:var(--yellow);border-radius:20px;color:var(--ink)}
  .price>strong{display:block;font-size:60px;line-height:1.2;font-family:Rockwell,Georgia,serif}
  .price .btn{display:flex;margin-top:10px}.price small{display:block;margin-top:17px}
